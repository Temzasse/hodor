{
  "name": "oxlint-preset-hodor",
  "version": "0.1.0",
  "description": "Hodor oxlint plugin keeps the AI slop out of your codebase.",
  "type": "module",
  "main": "lint/index.js",
  "exports": "./lint/index.js",
  "scripts": {
    "check": "node --check lint/index.js && node --check lint/plugin.js && node --check lint/utils.js && node --check lint/rules/index.js && find lint/rules -name rule.js -exec node --check {} \\;",
    "fmt": "oxfmt lint package.json oxlint.config.mjs tsconfig.json",
    "fmt:check": "oxfmt --check lint package.json oxlint.config.mjs tsconfig.json",
    "lint": "oxlint --config oxlint.config.mjs --ignore-pattern 'lint/rules/*/fixtures/**' .",
    "lint:fix": "oxlint --fix --config oxlint.config.mjs --ignore-pattern 'lint/rules/*/fixtures/**' .",
    "typecheck": "tsgo --noEmit -p tsconfig.json",
    "test": "vitest run"
  },
  "dependencies": {
    "@oxlint/plugins": "1.71.0"
  },
  "devDependencies": {
    "@types/node": "26.0.1",
    "@types/react": "19.2.17",
    "@typescript/native-preview": "7.0.0-dev.20260628.1",
    "oxfmt": "0.56.0",
    "oxlint": "1.71.0",
    "vitest": "4.1.9"
  },
  "peerDependencies": {
    "oxlint": ">=1"
  }
}
