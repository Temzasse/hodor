{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "allowJs": true,
    "checkJs": true,
    "jsx": "react-jsx",
    "types": ["node", "vitest"],
    "strict": true,
    "noEmit": true
  },
  "include": ["src", "tests"],
  "exclude": ["tests/**/fixtures"]
}
